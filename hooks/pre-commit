#!/bin/sh
# Pre-commit guard, shared via devenv_utils: the vendored subtrees under
# subtrees/<dir>/ are READ-ONLY mirrors of an upstream repo and may change only
# via `git subtree pull` (a merge commit, which git exempts from pre-commit).
# Delegates to the vendored subtree_guard.py so the hook and CI share one check.
#
# This hook lives inside the subtree, so any consuming repo activates it with
# `git config core.hooksPath <prefix>/hooks` (DevTool.ensure_git_hooks does
# this). It locates subtree_guard.py relative to itself, so the prefix can be
# anything.

hook_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
guard="$hook_dir/../subtree_guard.py"

if command -v python3 >/dev/null 2>&1; then
    exec python3 "$guard" --staged
fi

echo "pre-commit: python3 not found; skipping subtree-readonly check (CI still enforces it)." >&2
